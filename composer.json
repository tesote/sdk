{
    "name": "tesote/sdk",
    "description": "Official PHP client SDK for the equipo.tesote.com API.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://www.tesote.com/docs/sdk/php",
    "keywords": ["tesote", "sdk", "api", "banking", "payments"],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10 || ^11",
        "phpstan/phpstan": "^1 || ^2",
        "friendsofphp/php-cs-fixer": "^3"
    },
    "autoload": {
        "psr-4": {
            "Tesote\\Sdk\\": "packages/php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tesote\\Sdk\\Tests\\": "packages/php/tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c packages/php/phpunit.xml.dist",
        "phpstan": "phpstan analyse -c packages/php/phpstan.neon --memory-limit=512M",
        "cs-check": "php-cs-fixer fix --config=packages/php/.php-cs-fixer.dist.php --dry-run --diff",
        "cs-fix": "php-cs-fixer fix --config=packages/php/.php-cs-fixer.dist.php"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
